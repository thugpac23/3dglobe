generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserProfile {
  id          String   @id
  displayName String
  color       String
  protected   Boolean  @default(false)
  createdAt   DateTime @default(now())

  stamps   PassportStamp[]
  visits   Visit[]
  wishlist Wishlist[]
  progress UserProgress?
  avatar   Avatar?
  entries  DiaryEntry[]

  @@map("user_profiles")
}

model Country {
  id             String          @id @default(cuid())
  name           String
  capital        String
  isoCode        String          @unique
  visits         Visit[]
  wishlist       Wishlist[]
  passportStamps PassportStamp[]

  @@map("countries")
}

model PassportStamp {
  id        String      @id @default(cuid())
  userId    String
  user      UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  countryId String
  stampedAt DateTime    @default(now())
  page      Int         @default(0)
  positionX Float       @default(50)
  positionY Float       @default(50)
  rotation  Float       @default(0)
  country   Country     @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@unique([countryId, userId])
  @@map("passport_stamps")
}

model Visit {
  id        String      @id @default(cuid())
  countryId String
  userId    String
  user      UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())
  country   Country     @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@unique([countryId, userId])
  @@map("visits")
}

model Wishlist {
  id        String      @id @default(cuid())
  countryId String
  userId    String
  user      UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())
  country   Country     @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@unique([countryId, userId])
  @@map("wishlists")
}

model UserProgress {
  id           String      @id @default(cuid())
  userId       String      @unique
  user         UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  xp           Int         @default(0)
  level        Int         @default(1)
  achievements String      @default("[]")

  @@map("user_progress")
}

model Avatar {
  id          String      @id @default(cuid())
  userId      String      @unique
  user        UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  hairStyle   String      @default("short")
  hairColor   String      @default("#8B4513")
  eyeColor    String      @default("#4B5563")
  skinColor   String      @default("#FBBF8A")
  outfit      String      @default("casual")
  accessories String      @default("[]")
  faceType    String      @default("standard")
  expression  String      @default("smile")
  avatarUrl   String?

  @@map("avatars")
}

model Setting {
  key   String @id
  value String

  @@map("settings")
}

model DiaryEntry {
  id        String       @id @default(cuid())
  userId    String
  user      UserProfile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  content   String
  date      DateTime     @default(now())
  photos    DiaryPhoto[]

  @@map("diary_entries")
}

model DiaryPhoto {
  id           String     @id @default(cuid())
  diaryEntryId String
  url          String
  positionX    Float      @default(50)
  positionY    Float      @default(20)
  rotation     Float      @default(-3)
  caption      String     @default("")
  createdAt    DateTime   @default(now())
  diaryEntry   DiaryEntry @relation(fields: [diaryEntryId], references: [id], onDelete: Cascade)

  @@index([diaryEntryId])
  @@map("diary_photos")
}
