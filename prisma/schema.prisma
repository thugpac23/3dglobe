generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Country {
  id             String          @id @default(cuid())
  name           String
  capital        String
  isoCode        String          @unique
  visits         Visit[]
  wishlist       Wishlist[]
  passportStamps PassportStamp[]

  @@map("countries")
}

model PassportStamp {
  id        String   @id @default(cuid())
  user      User
  countryId String
  stampedAt DateTime @default(now())
  page      Int      @default(0)
  positionX Float    @default(50)
  positionY Float    @default(50)
  rotation  Float    @default(0)
  country   Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@unique([countryId, user])
  @@map("passport_stamps")
}

model Visit {
  id        String   @id @default(cuid())
  countryId String
  user      User
  createdAt DateTime @default(now())
  country   Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@unique([countryId, user])
  @@map("visits")
}

model Wishlist {
  id        String   @id @default(cuid())
  countryId String
  user      User
  createdAt DateTime @default(now())
  country   Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@unique([countryId, user])
  @@map("wishlists")
}

model UserProgress {
  id           String @id @default(cuid())
  user         User   @unique
  xp           Int    @default(0)
  level        Int    @default(1)
  achievements String @default("[]")

  @@map("user_progress")
}

model Avatar {
  id          String  @id @default(cuid())
  user        User    @unique
  hairStyle   String  @default("short")
  hairColor   String  @default("#8B4513")
  eyeColor    String  @default("#4B5563")
  skinColor   String  @default("#FBBF8A")
  outfit      String  @default("casual")
  accessories String  @default("[]")
  faceType    String  @default("standard")
  expression  String  @default("smile")
  avatarUrl   String?

  @@map("avatars")
}

enum User {
  tati
  iva
}
